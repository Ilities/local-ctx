{
  "name": "@ilities/local-ctx",
  "version": "0.4.3",
  "description": "An MCP utility to enable local servers to be exposed to standard clients with OAuth",
  "type": "module",
  "bin": {
    "local-ctx": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node esbuild.js",
    "start": "tsx src/index -c config.json",
    "format": "prettier --write \"src/**/*.{ts,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js}\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^4.22.1",
    "jose": "^6.2.2",
    "pino": "^10.3.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/prettier": "^3.0.0",
    "@types/yargs": "^17.0.35",
    "esbuild": "^0.24.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
