{
  "name": "@ilities/local-ctx",
  "version": "0.4.3",
  "description": "An MCP utility to enable local servers to be exposed to standard clients with OAuth",
  "type": "module",
  "bin": {
    "local-ctx": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node esbuild.js",
    "start": "tsx src/index -c config.json",
    "format": "prettier --write \"src/**/*.{ts,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js}\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jose": "^6.2.1",
    "pino": "^10.3.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.15",
    "@types/prettier": "^2.7.3",
    "@types/yargs": "^17.0.35",
    "esbuild": "^0.27.4",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
