{
  "name": "@ilities/local-ctx",
  "version": "0.4.3",
  "description": "An MCP utility to enable local servers to be exposed to standard clients with OAuth",
  "type": "module",
  "bin": {
    "local-ctx": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npx -y esbuild src/index.ts --bundle --outdir=dist --platform=node --target=node18 --format=esm --sourcemap --external:express --external:body-parser --external:fs --external:path --external:os --external:util --external:events --external:http --external:https --external:net --external:crypto --external:zlib --external:buffer --external:string_decoder --external:querystring --external:url --external:stream --external:node:path --external:node:fs --external:node:os --external:node:util --external:node:events --external:node:stream --external:node:http --external:node:https --external:node:net --external:node:crypto --external:node:zlib --external:node:buffer --external:node:string_decoder --external:node:querystring --external:node:url --external:dotenv --external:yargs --external:jose --external:@modelcontextprotocol/sdk --external:pino --external:pino-pretty",
    "start": "tsx src/index -c config.json",
    "format": "prettier --write \"src/**/*.{ts,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js}\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jose": "^6.2.1",
    "pino": "^10.3.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.15",
    "@types/prettier": "^2.7.3",
    "@types/yargs": "^17.0.35",
    "esbuild": "^0.27.4",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
